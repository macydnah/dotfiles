{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "plan",
  "model": "github-copilot/gpt-5-mini",
  "small_model": "github-copilot/gpt-4.1",
  "share": "manual",
  "permission": {
    "bash": {
      // "git commit *": "deny",
      "git push *": "deny",
      "rm *": "deny"
    }
  },
  "compaction": {
    "auto": false,
    "prune": true
  },
  "lsp": {
    "basedpyright": {
      "disabled": false,
      "command": [ "basedpyright-langserver", "--stdio" ],
      "extensions": [ ".py", ".pyi" ]
    }
  }
}
